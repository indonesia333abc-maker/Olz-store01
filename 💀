<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>OLZ STORE - Red Matrix</title>
<style>
body{
    margin:0;
    background:black;
    font-family:Courier New, monospace;
    color:red;
    overflow:hidden;
}

/* Canvas Matrix */
canvas{
    position:fixed;
    top:0;
    left:0;
    z-index:0;
}

/* Centralização perfeita */
.centralizar{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    z-index:2;
}

/* Caixa */
.box{
    background:rgba(20,0,0,0.9);
    padding:30px;
    width:320px;
    border-radius:10px;
    text-align:center;
    border:1px solid red;
    box-shadow:0 0 25px red;
}

h2{
    text-shadow:0 0 10px red;
}

input{
    width:100%;
    padding:10px;
    margin:8px 0;
    background:black;
    border:1px solid red;
    color:red;
    text-align:center;
}

button{
    width:100%;
    padding:10px;
    margin-top:10px;
    background:red;
    border:none;
    color:black;
    font-weight:bold;
    cursor:pointer;
}

#erro{
    margin-top:10px;
    color:orange;
    display:none;
}

/* Painel */
#painel{
    display:none;
}

.opcao{
    border:1px solid red;
    padding:8px;
    margin:5px 0;
    cursor:pointer;
}
.opcao:hover{
    background:red;
    color:black;
}

#botao{
    display:none;
}

.barra-container{
    width:100%;
    height:8px;
    background:black;
    margin-top:10px;
    display:none;
}
.barra{
    height:100%;
    width:0%;
    background:red;
}

#notificacao{
    display:none;
    margin-top:10px;
    color:yellow;
}

#opcoesFF button{
    width:48%;
    margin-top:5px;
}
</style>
</head>
<body>

<canvas id="matrix"></canvas>

<!-- LOGIN CENTRALIZADO -->
<div class="centralizar" id="loginBox">
    <div class="box">
        <h2>OLZ STORE</h2>
        <input type="text" id="usuario" placeholder="Usuário">
        <input type="password" id="senha" placeholder="Senha">
        <button id="btnLogin">Entrar</button>
        <div id="erro"></div>
    </div>
</div>

<!-- PAINEL CENTRALIZADO -->
<div class="centralizar" id="painel">
    <div class="box">
        <h2>OLZ STORE</h2>

        <div class="opcao">Pé</div>
        <div class="opcao">Cabeça de Baixo</div>
        <div class="opcao">Barriga</div>
        <div class="opcao">Pescoço</div>
        <div class="opcao">Full Cabeça</div>

        <button id="botao">Injetar</button>

        <div class="barra-container">
            <div class="barra"></div>
        </div>

        <div id="notificacao">Entre e brilhe</div>

        <!-- Opções FF -->
        <div id="opcoesFF" style="display:none; text-align:center;">
            <button id="ffMax">Injetar FF Max</button>
            <button id="ffNormal">Injetar FF Normal</button>
        </div>

    </div>
</div>

<script>
// MATRIX VERMELHO
const canvas=document.getElementById("matrix");
const ctx=canvas.getContext("2d");
canvas.width=window.innerWidth;
canvas.height=window.innerHeight;
const letters="01ABCDEFGHIJKLMNOPQRSTUVWXYZ";
const fontSize=14;
const columns=Math.floor(canvas.width/fontSize);
const drops=[];
for(let x=0;x<columns;x++) drops[x]=1;
function draw(){
    ctx.fillStyle="rgba(0,0,0,0.05)";
    ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle="red";
    ctx.font=fontSize+"px monospace";
    for(let i=0;i<drops.length;i++){
        const text=letters.charAt(Math.floor(Math.random()*letters.length));
        ctx.fillText(text,i*fontSize,drops[i]*fontSize);
        if(drops[i]*fontSize>canvas.height && Math.random()>0.975) drops[i]=0;
        drops[i]++;
    }
}
setInterval(draw,35);

// LOGIN
const usuarioCorreto="uriel";
const senhaCorreta="xiter";
let tentativas=0;

document.getElementById("btnLogin").addEventListener("click",function(){
    const user=document.getElementById("usuario").value;
    const pass=document.getElementById("senha").value;
    const erro=document.getElementById("erro");

    if(tentativas>=3){
        erro.style.display="block";
        erro.innerText="LOGIN BLOQUEADO";
        return;
    }

    if(user===usuarioCorreto && pass===senhaCorreta){
        document.getElementById("loginBox").style.display="none";
        document.getElementById("painel").style.display="block";
    }else{
        tentativas++;
        erro.style.display="block";
        erro.innerText="ACESSO NEGADO ("+tentativas+"/3)";
    }
});

// PAINEL
const opcoes=document.querySelectorAll(".opcao");
const botao=document.getElementById("botao");
const barra=document.querySelector(".barra");
const barraContainer=document.querySelector(".barra-container");
const notificacao=document.getElementById("notificacao");
const opcoesFF=document.getElementById("opcoesFF");

opcoes.forEach(op=>{
    op.addEventListener("click",()=>{
        botao.style.display="block";
        barraContainer.style.display="none";
        notificacao.style.display="none";
        barra.style.width="0%";
        opcoesFF.style.display="none";
    });
});

botao.addEventListener("click",()=>{
    barraContainer.style.display="block";
    let progresso=0;
    let intervalo=setInterval(()=>{
        progresso+=2;
        barra.style.width=progresso+"%";
        if(progresso>=100){
            clearInterval(intervalo);
            notificacao.style.display="block";
            opcoesFF.style.display="block";
        }
    },100);
});

// Ações botões FF (links oficiais)
document.getElementById("ffMax").addEventListener("click",()=>{
    window.open("https://ff.garena.com/ffmax","_blank");
});
document.getElementById("ffNormal").addEventListener("click",()=>{
    window.open("https://ff.garena.com/","_blank");
});
</script>

</body>
</html>
